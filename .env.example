# ──────────────────────────────────────────────
# Azure Environment Configuration
# ──────────────────────────────────────────────

# Azure region (e.g. centralindia, eastus, westeurope)
AZURE_LOCATION=centralindia
AZURE_ENV_NAME=dev

# ── Blob Storage (Phase 2) ──
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_NAME=uploads
AZURE_STORAGE_CONNECTION_STRING=

# ── Cosmos DB (Phase 3) ──
COSMOS_ENDPOINT=
COSMOS_DATABASE_NAME=chatbot
COSMOS_CONTAINER_NAME=conversations
COSMOS_KEY=

# ── Clerk Auth ──
# Required: Clerk Dashboard → Configure → Developers → API keys → Frontend API URL
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
# Optional; defaults to {CLERK_ISSUER}/.well-known/jwks.json
CLERK_JWKS_URL=
# Comma-separated origins allowed in the token azp claim (CSRF protection)
# Include local dev port and production Static Web App URL (no trailing slash on URLs)
CLERK_AUTHORIZED_PARTIES=http://localhost:3333,https://ambitious-bay-08c170100.7.azurestaticapps.net
# Secret key: store in Key Vault as clerk-secret-key (see docs/CLERK_AUTH_SETUP.md).
# Only set here temporarily for `make deploy-infra` or local bootstrap — do not commit.
# CLERK_SECRET_KEY=

# ── Storage Queue (Phase 5 — uses same Storage Account) ──
AZURE_INGESTION_QUEUE_NAME=ingestion-queue

# ── Document Intelligence (Phase 5) ──
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ── Key Vault (Phase 6) ──
AZURE_KEYVAULT_NAME=

# ── Container Apps (Phase 7) ──
AZURE_CONTAINER_REGISTRY=
AZURE_CONTAINER_APP_NAME=chatbot-backend

# ── LLM (unchanged — cloud-agnostic via LiteLLM) ──
LITELLM_MODEL=gpt-4o-mini
LITELLM_API_KEY=
LITELLM_BASE_URL=
LITELLM_VISION_MODEL=gemini/gemini-3.1-flash-lite
LITELLM_VISION_API_KEY=
LITELLM_VISION_BASE_URL=
LITELLM_EMBEDDING_MODEL=gemini/gemini-embedding-2
LITELLM_EMBEDDING_API_KEY=

# ── RAG Config (unchanged) ──
EMBEDDING_DIMENSION=768
RAG_TOP_K=3
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=80

# ── App Config (unchanged) ──
CONTEXT_TTL_SECONDS=3600
MAX_IMAGE_BYTES=5242880
ALLOWED_IMAGE_MIME_TYPES=image/png,image/jpeg,image/webp
MAX_HISTORY_MESSAGES=10
LOG_LEVEL=INFO
