AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_SESSION_TOKEN=

DYNAMODB_TABLE_NAME=chatbot
DYNAMODB_ENDPOINT_URL=http://localhost:8000

S3_BUCKET_NAME=chatbot-uploads
S3_ENDPOINT_URL=http://localhost:9000
S3_FORCE_PATH_STYLE=true

LITELLM_MODEL=gpt-4o-mini
LITELLM_API_KEY=your_model_key
LITELLM_BASE_URL=

LITELLM_VISION_MODEL=gemini/gemini-3.1-flash-lite
LITELLM_VISION_API_KEY=your_vision_key
LITELLM_VISION_BASE_URL=

LITELLM_EMBEDDING_MODEL=gemini/gemini-embedding-2
LITELLM_EMBEDDING_API_KEY=
S3_VECTOR_BUCKET_NAME=chatbot-vectors-prod
S3_VECTOR_INDEX_NAME=enterprise-kb
S3_VECTOR_ENDPOINT_URL=
EMBEDDING_DIMENSION=768
RAG_TOP_K=3
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=80

CONTEXT_TTL_SECONDS=3600
MAX_IMAGE_BYTES=5242880
ALLOWED_IMAGE_MIME_TYPES=image/png,image/jpeg,image/webp
MAX_HISTORY_MESSAGES=10

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
