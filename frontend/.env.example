# Dev Server port
PORT=3000

# Backend API Endpoint Base URL (Local API or AWS API Gateway HTTP API)
VITE_API_BASE_URL=http://localhost:8080

# Allowed hosts for development (comma-separated, optional)
ALLOWED_HOSTS=localhost,127.0.0.1

# Clerk — Dashboard → Configure → Developers → API keys → Publishable key
# Use frontend/.env (not repo root). Never put CLERK_SECRET_KEY here.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
